generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MODULE 1 — Authentification et gestion des rôles
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  ptaCode       String?   @unique
  position      String?
  department    String?
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  isLocked               Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lastLoginAt            DateTime?
  passwordChangedAt      DateTime?
  deletedAt     DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roles         UserRole[]
  auditLogs     AuditLog[]

  directionsHead Direction[] @relation("DirectionHead")
  unitsHead      Unit[]      @relation("UnitHead")

  activitiesResponsible Activity[]  @relation("ActivityResponsible")
  activitiesValidator   Activity[]  @relation("ActivityValidator")
  activitiesCreatedBy   Activity[]  @relation("ActivityCreatedBy")
  activitiesUpdatedBy   Activity[]  @relation("ActivityUpdatedBy")

  uploadedEvidence   EvidenceFile[] @relation("EvidenceUploader")
  verifiedEvidence   EvidenceFile[] @relation("EvidenceVerifier")
  raciResponsible   RaciMatrix[]   @relation("RaciResponsible")
  raciAccountable   RaciMatrix[]   @relation("RaciAccountable")
  raciCreated       RaciMatrix[]   @relation("RaciCreator")

  reportTemplatesCreated ReportTemplate[] @relation("TemplateCreator")
  reportsGenerated       Report[]         @relation("ReportGenerator")
  reportsValidated       Report[]         @relation("ReportValidator")

  notificationsReceived  Notification[]   @relation("NotificationRecipient")
  notificationsSent      Notification[]   @relation("NotificationSender")
  notificationPreferences NotificationPreference? @relation("NotificationPreferences")
  importsUploaded        ImportHistory[]  @relation("ImportUploader")
  exportsGenerated       ExportJob[]     @relation("ExportGenerator")

  @@map("users")
}

model Role {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  isSystem    Boolean   @default(false)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  module      String
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  ipAddress  String?
  userAgent  String?
  details    String?  @db.Text
  severity   String   @default("info") // "info", "warning", "critical"

  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@index([severity])
  @@map("audit_logs")
}

// ============================================================
// MODULE 2 — Administration organisationnelle AAEA
// ============================================================

model Direction {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  headUserId  String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  units       Unit[]
  headUser    User?     @relation("DirectionHead", fields: [headUserId], references: [id], onDelete: SetNull)
  activities  Activity[]
  kpiDefinitions KpiDefinition[]
  reports     Report[]

  @@map("directions")
}

model Unit {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?   @db.Text
  directionId String
  headUserId  String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  direction   Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
  headUser    User?     @relation("UnitHead", fields: [headUserId], references: [id], onDelete: SetNull)

  @@map("units")
}

// ============================================================
// MODULE 3 — Référentiel stratégique
// ============================================================

model StrategicAxis {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  objective       String?   @db.Text
  expectedResults String?   @db.Text
  indicators      String?   @db.Text
  concernedUnits  String?   @db.Text
  order           Int       @default(0)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  activitiesPrimary   Activity[] @relation("PrimaryAxis")
  activitiesSecondary Activity[] @relation("SecondaryAxis")
  raciMatrices        RaciMatrix[]
  kpiDefinitions      KpiDefinition[]
  reports             Report[]

  @@map("strategic_axes")
}

// ============================================================
// MODULE 4 — Référentiel ACBF
// ============================================================

model AcbfDomain {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deliverables      AcbfDeliverable[]
  activities        Activity[]
  reports           Report[]

  @@map("acbf_domains")
}

model AcbfDeliverable {
  id          String    @id @default(cuid())
  domainId    String
  code        String    @unique
  name        String
  description String?   @db.Text
  priority    String?
  status      String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  domain      AcbfDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  activities  Activity[]
  evidenceFiles EvidenceFile[]
  raciMatrix  RaciMatrix?

  @@map("acbf_deliverables")
}

// ============================================================
// MODULE 5 — Gestion des PTA individuels
// ============================================================

model Activity {
  id                   String    @id @default(cuid())
  activityCode         String    @unique
  responsibleId        String
  directionId          String?
  primaryAxisId        String?
  secondaryAxisId      String?
  acbfDomainId         String?
  acbfDeliverableId    String?
  annualObjective      String?   @db.Text
  title                String
  detailedTasks        String?   @db.Text
  expectedDeliverable  String?   @db.Text
  validatorId          String?
  startDate            DateTime?
  endDate              DateTime?
  priority             String    @default("Moyenne")
  performanceIndicator String?   @db.Text
  verificationSource   String?   @db.Text
  status               String    @default("Non démarré")
  progressRate         Float     @default(0)
  riskDescription      String?   @db.Text
  comments             String?   @db.Text
  validationStatus     String    @default("Brouillon")
  nature               String?
  dependency           String?   @db.Text
  duration             String?

  isLocked             Boolean   @default(false)
  isActive             Boolean   @default(true)
  deletedAt            DateTime?

  createdById          String?
  updatedById          String?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  responsible          User           @relation("ActivityResponsible", fields: [responsibleId], references: [id], onDelete: Restrict)
  direction            Direction?     @relation(fields: [directionId], references: [id], onDelete: SetNull)
  primaryAxis          StrategicAxis? @relation("PrimaryAxis", fields: [primaryAxisId], references: [id], onDelete: SetNull)
  secondaryAxis        StrategicAxis? @relation("SecondaryAxis", fields: [secondaryAxisId], references: [id], onDelete: SetNull)
  acbfDomain           AcbfDomain?    @relation(fields: [acbfDomainId], references: [id], onDelete: SetNull)
  acbfDeliverable      AcbfDeliverable? @relation(fields: [acbfDeliverableId], references: [id], onDelete: SetNull)
  validator            User?          @relation("ActivityValidator", fields: [validatorId], references: [id], onDelete: SetNull)
  createdBy            User?          @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?          @relation("ActivityUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  evidenceFiles        EvidenceFile[]
  raciMatrix           RaciMatrix?

  @@map("activities")
}

// ============================================================
// MODULE 7 — Gestion documentaire et preuves
// ============================================================

model EvidenceFile {
  id                String    @id @default(cuid())
  name              String
  originalName      String
  fileType          String    // "file", "link"
  mimeType          String?   // MIME type for files
  fileSize          Int?      // Size in bytes
  url               String    // File path or external URL
  description       String?   @db.Text
  category          String    // "Rapport", "PV", "Photo", "Lien", "Source de vérification", "Autre"
  version           String?   // e.g. "v1", "v2"
  isVerified        Boolean   @default(false)
  verifiedById      String?
  verifiedAt        DateTime?

  activityId        String?
  acbfDeliverableId String?

  isActive          Boolean   @default(true)
  deletedAt         DateTime?

  uploadedById      String

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activity          Activity?         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  acbfDeliverable   AcbfDeliverable?  @relation(fields: [acbfDeliverableId], references: [id], onDelete: Cascade)
  verifiedBy        User?             @relation("EvidenceVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  uploadedBy        User              @relation("EvidenceUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@map("evidence_files")
}

// ============================================================
// MODULE 8 — Matrice RACI
// ============================================================

model RaciMatrix {
  id                String    @id @default(cuid())
  acbfDeliverableId String?   @unique // Link to ACBF deliverable (1:1)
  activityId        String?   @unique // Optional link to Activity (1:1)
  strategicAxisId   String?   // Principal strategic axis

  responsible       String?   @db.Text  // R — text description (e.g. "Directeur Exécutif")
  responsibleUserId String?             // Optional FK to User for R
  accountable       String?   @db.Text  // A — text description (e.g. "Conseil / Direction Exécutive")
  accountableUserId String?             // Optional FK to User for A
  contributors      String?   @db.Text  // C — semicolon-separated text (e.g. "Conformité; DAF; DSMP; MEAL")
  informed          String?   @db.Text  // I — semicolon-separated text (e.g. "Direction Exécutive; équipes concernées")

  priority          String?             // Niveau de priorité
  indicativeDeadline DateTime?          // Échéance indicative
  verificationSource String?  @db.Text  // Source de vérification attendue
  comments          String?  @db.Text

  isActive          Boolean   @default(true)
  deletedAt         DateTime?

  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  acbfDeliverable   AcbfDeliverable? @relation(fields: [acbfDeliverableId], references: [id], onDelete: Cascade)
  activity          Activity?        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  strategicAxis     StrategicAxis?   @relation(fields: [strategicAxisId], references: [id], onDelete: SetNull)
  responsibleUser   User?            @relation("RaciResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  accountableUser   User?            @relation("RaciAccountable", fields: [accountableUserId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("RaciCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("raci_matrix")
}

// ============================================================
// MODULE 10 — Tableaux de bord et indicateurs de performance
// ============================================================

model KpiDefinition {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  description     String?   @db.Text
  category        String    // "Stratégique", "Opérationnel", "Organisationnel", "Qualité"
  targetValue     Float     @default(0)
  currentValue    Float     @default(0)
  unit            String?   // "%", "Nombre", "Jours", "Score"
  direction       String    @default("higher") // "higher" = plus haut est mieux, "lower" = plus bas est mieux
  frequency       String    @default("Mensuel") // "Quotidien", "Hebdomadaire", "Mensuel", "Trimestriel", "Annuel"
  strategicAxisId String?
  directionId     String?
  isPublic        Boolean   @default(true)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  strategicAxis   StrategicAxis? @relation(fields: [strategicAxisId], references: [id], onDelete: SetNull)
  orgDirection    Direction?     @relation(fields: [directionId], references: [id], onDelete: SetNull)
  snapshots       KpiSnapshot[]

  @@index([deletedAt, isActive])
  @@index([category])
  @@index([directionId])
  @@index([strategicAxisId])
  @@map("kpi_definitions")
}

model KpiSnapshot {
  id              String    @id @default(cuid())
  kpiId           String
  value           Float
  targetValue     Float
  period          String    // "2026-01", "2026-Q1", "2026", etc.
  capturedAt      DateTime  @default(now())
  notes           String?   @db.Text

  kpi             KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, period])
  @@index([kpiId])
  @@index([capturedAt])
  @@map("kpi_snapshots")
}

// ============================================================
// MODULE 11 — Reporting automatique
// ============================================================

model ReportTemplate {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  description     String?   @db.Text
  type            String    // "Mensuel", "Trimestriel", "Annuel", "ACBF", "Par axe", "Par direction", "Personnalisé"
  category        String    @default("Général") // "Général", "Stratégique", "Opérationnel", "ACBF", "Finance"
  periodFormat    String    @default("YYYY-MM") // "YYYY-MM", "YYYY-QN", "YYYY", "custom"
  sections        String?   @db.Text // JSON string defining report sections/structure
  filters         String?   @db.Text // JSON string with default filters (directionId, axisId, etc.)
  isSystem        Boolean   @default(false) // System templates can't be deleted
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  createdById     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy       User?     @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reports         Report[]

  @@index([type])
  @@index([category])
  @@index([isActive, deletedAt])
  @@map("report_templates")
}

model Report {
  id              String    @id @default(cuid())
  templateId      String
  title           String
  period          String    // "2026-01", "2026-Q1", "2026", etc.
  status          String    @default("Brouillon") // "Brouillon", "Généré", "Validé", "Rejeté", "Archivé"
  type            String    // Inherited from template
  data            String?   @db.Text // JSON string with aggregated report data
  summary         String?   @db.Text // Executive summary text
  generatedAt     DateTime?
  validatedAt     DateTime?
  validatedById   String?
  generatedById   String?

  // Filters used for generation
  directionId     String?
  strategicAxisId String?
  acbfDomainId    String?

  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  template        ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  validatedBy     User?          @relation("ReportValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  generatedBy     User?          @relation("ReportGenerator", fields: [generatedById], references: [id], onDelete: SetNull)
  direction       Direction?     @relation(fields: [directionId], references: [id], onDelete: SetNull)
  strategicAxis   StrategicAxis? @relation(fields: [strategicAxisId], references: [id], onDelete: SetNull)
  acbfDomain      AcbfDomain?    @relation(fields: [acbfDomainId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([status])
  @@index([type])
  @@index([generatedAt])
  @@index([isActive, deletedAt])
  @@map("reports")
}

// ============================================================
// MODULE 12 — Notifications et alertes
// ============================================================

model Notification {
  id           String    @id @default(cuid())
  userId       String    // Destinataire
  title        String
  message      String    @db.Text
  type         String    // "info", "warning", "error", "success", "alert"
  category     String    @default("système") // "activité", "échéance", "validation", "rapport", "système", "alerte"
  priority     String    @default("normale") // "basse", "normale", "haute", "urgente"
  isRead       Boolean   @default(false)
  readAt       DateTime?
  actionUrl    String?   // Lien vers l'entité concernée (ex: /api/activities/xxx)
  entityId     String?   // ID de l'entité liée
  entityType   String?   // "Activity", "Report", "EvidenceFile", etc.
  sentByEmail  Boolean   @default(false)
  sentAt       DateTime? // Date d'envoi (null = pas encore envoyé)
  expiresAt    DateTime? // Date d'expiration (optionnelle)

  isActive     Boolean   @default(true)
  deletedAt    DateTime?

  createdById  String?   // Expéditeur (null = système)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  createdBy    User?     @relation("NotificationSender", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, category])
  @@index([expiresAt])
  @@map("notifications")
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(true)
  pushEnabled           Boolean  @default(false)
  activityAlerts        Boolean  @default(true)
  deadlineReminders     Boolean  @default(true)
  validationAlerts      Boolean  @default(true)
  reportAlerts          Boolean  @default(true)
  systemAlerts          Boolean  @default(true)
  deadlineReminderDays  Int      @default(3) // Jours avant échéance pour rappel
  quietHoursStart       String?  // "22:00" — début des heures silencieuses
  quietHoursEnd         String?  // "08:00" — fin des heures silencieuses

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation("NotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============================================================
// MODULE 14 — Import Excel
// ============================================================

model ImportHistory {
  id              String    @id @default(cuid())
  fileName        String
  fileSize        Int
  fileType        String    // "xlsx", "xls", "csv"
  status          String    @default("En attente") // "En attente", "En cours", "Terminé", "Erreur", "Partiel"
  sheets          String?   @db.Text // JSON array of sheet names found
  selectedSheets  String?   @db.Text // JSON array of selected sheets for import
  mapping         String?   @db.Text // JSON object with column mapping config
  totalRows       Int       @default(0)
  processedRows   Int       @default(0)
  createdRows     Int       @default(0)
  updatedRows     Int       @default(0)
  skippedRows     Int       @default(0)
  errorRows       Int       @default(0)
  errors          String?   @db.Text // JSON array of error objects [{row, column, message}]
  previewData     String?   @db.Text // JSON with first 5 rows preview per sheet
  startedAt       DateTime?
  completedAt     DateTime?

  uploadedById    String

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  uploadedBy      User      @relation("ImportUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([uploadedById])
  @@index([createdAt])
  @@map("import_history")
}

// ============================================================
// MODULE 15 — Exports PDF, Excel et Word
// ============================================================

model ExportJob {
  id              String    @id @default(cuid())
  type            String    // "pta", "dashboard", "report", "gantt", "raci", "evidence"
  format          String    // "pdf", "xlsx", "docx"
  title           String    // User-friendly title for the export
  status          String    @default("En attente") // "En attente", "En cours", "Terminé", "Erreur"
  fileName        String?   // Generated file name
  fileSize        Int       @default(0) // Size in bytes
  fileData        Bytes?    // File content stored as binary (works on Vercel read-only FS)
  filters         String?   @db.Text // JSON string with filters used for generation
  recordCount     Int       @default(0) // Number of records included
  errorMessage    String?   @db.Text // Error message if failed
  startedAt       DateTime?
  completedAt     DateTime?

  generatedById   String

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  generatedBy     User      @relation("ExportGenerator", fields: [generatedById], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([format])
  @@index([status])
  @@index([generatedById])
  @@index([createdAt])
  @@map("export_jobs")
}

// ============================================================
// Paramètres de l'application
// ============================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
